{
  "name": "juuksuri-kodutoo",
  "version": "0.1.0",
  "type": "module",
  "description": "Juuksurisalongi broneerimissüsteem (TAK25 kodutöö)",
  "scripts": {
    "dev": "bun run --hot src/index.tsx",
    "start": "bun run src/index.tsx",
    "migrate": "bun run src/db/migrate.ts",
    "seed": "bun run src/db/seed.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check ."
  },
  "dependencies": {
    "hono": "^4.6.14",
    "postgres": "^3.4.5",
    "zod": "^3.24.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
